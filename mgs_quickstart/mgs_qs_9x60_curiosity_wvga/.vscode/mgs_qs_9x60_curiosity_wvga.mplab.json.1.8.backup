{
    "version": "1.8",
    "configurations": [
        {
            "name": "default",
            "id": "conf1",
            "device": "SAM9X60D1G",
            "imagePath": "./out/mgs_qs_9x60_curiosity_wvga/default.elf",
            "packs": [
                {
                    "name": "SAM9X6_DFP",
                    "vendor": "Microchip",
                    "version": "1.14.267"
                }
            ],
            "fileSet": "default",
            "toolchain": "default-XC32"
        }
    ],
    "propertyGroups": [
        {
            "name": "default-XC32",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc32@5.00",
            "properties": {
                "compiler.isolate-each-function": true,
                "compiler.optimization-level": "-O1",
                "compiler.place-data-into-section": true,
                "linker.heap-size": "0",
                "linker.remove-unused-sections": true,
                "compiler++.isolate-each-function": true,
                "compiler++.optimization-level": "-O1",
                "compiler.additional-options": [
                    "-marm"
                ],
                "compiler++.extra-include-directories": [
                    "curiosity_wvga/mcc",
                    "curiosity_wvga/src",
                    "curiosity_wvga/src/config/default",
                    "curiosity_wvga/src/packs/SAM9X60D1G_DFP"
                ],
                "compiler.extra-include-directories": [
                    "curiosity_wvga/mcc",
                    "curiosity_wvga/src",
                    "curiosity_wvga/src/config/default",
                    "curiosity_wvga/src/packs/SAM9X60D1G_DFP"
                ],
                "linker.no-device-startup-code": "true"
            }
        }
    ],
    "fileSets": [
        {
            "name": "default",
